<section class="page-head"><h1>Market Search + Guided AI Questions</h1><p>Search uses Kunpeng Data when your API settings are configured. Otherwise, the app falls back to local sample data.</p></section><section class="grid two"><div class="card"><h2>1. Search shares or ETFs</h2><form method="GET" action="/search" class="stack"><label>Search</label><input name="q" value="<%= q || '' %>" placeholder="Apple, Tesla, Nvidia, VAS, ETF"><button>Search</button></form><p class="hint">Search source: <strong><%= searchSource %></strong></p><div class="search-results"><% results.slice(0,20).forEach(s => { %><div class="result-card"><div><strong><%= s.symbol %></strong><small><%= s.name %> — <%= s.sector || s.type %></small></div><span class="score <%= s.rating >= 85 ? 'good' : s.rating >= 70 ? 'watch' : 'risk' %>"><%= s.rating || "?" %></span><a class="small-button" href="/search?q=<%= encodeURIComponent(q || s.symbol) %>&symbol=<%= s.symbol %>">Select</a></div><% }) %></div></div><div class="card"><h2>2. Ask guided AI</h2><form method="POST" action="/search/ask" class="stack"><input type="hidden" name="q" value="<%= q || '' %>"><label>Main share</label><input name="symbol" value="<%= symbol || '' %>" placeholder="Example: AAPL, TSLA, BHP.AX"><label>Prompt</label><select name="promptId"><% prompts.forEach(p => { %><option value="<%= p.id %>" <%= selectedPrompt === p.id ? "selected" : "" %>><%= p.category %>: <%= p.label %></option><% }) %></select><label>Compare with</label><select name="compareSymbol"><option value="">No comparison</option><% stocks.forEach(s => { %><option value="<%= s.symbol %>" <%= compareSymbol === s.symbol ? "selected" : "" %>><%= s.symbol %> — <%= s.name %></option><% }) %></select><button>Ask AI</button></form><% if (symbol) { %><form method="POST" action="/watchlist/add" class="compact-form"><input type="hidden" name="symbol" value="<%= symbol %>"><button class="secondary">Add to Watchlist</button></form><form method="POST" action="/sandbox/buy" class="stack mini-trade"><input type="hidden" name="symbol" value="<%= symbol %>"><label>Fake buy units</label><input name="units" type="number" step="0.0001" value="1"><label>Reason</label><input name="reason" value="Testing idea from guided AI prompt"><button>Fake Buy Selected Share using market quote if available</button></form><a class="button secondary wide-link" href="/stock/<%= symbol %>">Open quote page</a><% } %></div></section><% if (answer) { %><section class="card coach-answer"><h2><%= answer.title %></h2><p class="lede"><%= answer.summary %></p><ul><% answer.points.forEach(p => { %><li><%= p %></li><% }) %></ul><p class="disclaimer">Educational information only. Not personal financial advice.</p></section><% } %>