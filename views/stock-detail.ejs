<section class="page-head"><h1><%= stock.symbol %> — <%= stock.name %></h1><p><%= stock.summary %></p></section><section class="grid two"><div class="card"><h2>Live Quote</h2><% if (liveQuote && liveQuote.quote) { const q = liveQuote.quote; %><div class="big-score">$<%= Number(q.c || 0).toFixed(2) %></div><p><strong>Source:</strong> <%= liveQuote.source %></p><p><strong>Open:</strong> $<%= Number(q.o || 0).toFixed(2) %></p><p><strong>High:</strong> $<%= Number(q.h || 0).toFixed(2) %></p><p><strong>Low:</strong> $<%= Number(q.l || 0).toFixed(2) %></p><p><strong>Previous close:</strong> $<%= Number(q.pc || 0).toFixed(2) %></p><% } else { %><p>No live quote available. Check Finnhub key or limits.</p><% } %></div><div class="card"><h2>Sandbox action</h2><% if (user) { %><form method="POST" action="/sandbox/buy" class="stack"><input type="hidden" name="symbol" value="<%= stock.symbol %>"><label>Units</label><input name="units" type="number" step="0.0001" value="1"><label>Reason</label><input name="reason"><button>Fake Buy using live quote if available</button></form><a class="button secondary wide-link" href="/search?symbol=<%= stock.symbol %>&q=<%= stock.symbol %>">Ask guided AI questions</a><% } else { %><p><a href="/login">Login</a> to use sandbox trading.</p><% } %></div></section><section class="card"><h2>Company Profile</h2><% if (profile && profile.profile && profile.profile.name) { %><p><strong>Name:</strong> <%= profile.profile.name %></p><p><strong>Country:</strong> <%= profile.profile.country %></p><p><strong>Currency:</strong> <%= profile.profile.currency %></p><p><strong>Exchange:</strong> <%= profile.profile.exchange %></p><% } else { %><p>Profile unavailable.</p><% } %></section><section class="card"><h2>Price History Graph</h2><p class="hint">Graph is still sample-generated. Live historical candles can be added next.</p><div class="chart-wrap"><canvas id="stockChart" width="900" height="320" data-symbol="<%= stock.symbol %>"></canvas></div></section>