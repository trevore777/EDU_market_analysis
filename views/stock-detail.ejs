<section class="page-head"><h1><%= stock.symbol %> — <%= stock.name %></h1><p><%= stock.summary %></p></section>
<section class="grid two">
<div class="card"><h2>Rating</h2><div class="big-score"><%= stock.rating %><span>/100</span></div><p><strong>Signal:</strong> <%= stock.signal %></p><p><strong>Zone:</strong> <%= stock.zone %></p><p><strong>Risk:</strong> <%= stock.risk %></p><p><strong>Sample price:</strong> $<%= stock.price.toFixed(2) %></p></div>
<div class="card"><h2>Sandbox action</h2><p>This creates a fake trade only. No real order is placed.</p>
<% if (user) { %>
<form method="POST" action="/sandbox/buy" class="stack">
<input type="hidden" name="symbol" value="<%= stock.symbol %>">
<label>Units to fake buy</label><input name="units" type="number" step="0.0001" value="1">
<label>Reason for trade</label><input name="reason" placeholder="Why are you testing this trade?">
<button>Fake Buy</button>
</form>
<a class="button secondary wide-link" href="/search?symbol=<%= stock.symbol %>&q=<%= stock.symbol %>">Ask guided AI questions</a>
<% } else { %><p><a href="/login">Login</a> to use sandbox trading.</p><% } %>
</div></section>
<section class="card"><h2>Score breakdown</h2><div class="bars">
<% [["Quality", stock.quality], ["Value", stock.value], ["Momentum", stock.momentum], ["Income", stock.income]].forEach(item => { %>
<div class="bar-row"><span><%= item[0] %></span><div class="bar"><i style="width:<%= item[1] %>%"></i></div><b><%= item[1] %></b></div>
<% }) %></div></section>

<section class="card">
  <h2>Price History Graph</h2>
  <p class="hint">Sample history chart. Later this can use live historical data from a market-data API.</p>
  <div class="chart-wrap">
    <canvas id="stockChart" width="900" height="320" data-symbol="<%= stock.symbol %>"></canvas>
  </div>
</section>