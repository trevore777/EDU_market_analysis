<section class="page-head"><h1>Sandbox Paper Trading</h1><p>Fake trades use live market quotes when available; otherwise local fallback data.</p></section><% if (message) { %><div class="success"><%= message %></div><% } %><% if (error) { %><div class="error"><%= error %></div><% } %><section class="grid four"><div class="metric"><span>Total virtual value</span><strong>$<%= stats.totalValue.toFixed(2) %></strong></div><div class="metric"><span>Virtual cash</span><strong>$<%= Number(stats.account.cash_balance).toFixed(2) %></strong></div><div class="metric"><span>Total return</span><strong><%= stats.totalGain >= 0 ? "+" : "" %>$<%= stats.totalGain.toFixed(2) %></strong></div><div class="metric"><span>Health score</span><strong><%= stats.healthScore %>/100</strong></div></section><section class="card"><h2>Sandbox Portfolio Graph</h2><div class="chart-wrap"><canvas id="sandboxChart" width="900" height="320"></canvas></div></section><section class="grid two"><div class="card"><h2>Fake Buy</h2><form method="POST" action="/sandbox/buy" class="stack"><label>Share / ETF</label><input name="symbol" placeholder="AAPL, TSLA, BHP.AX" required><label>Units</label><input name="units" type="number" step="0.0001" value="1"><label>Reason</label><input name="reason"><button>Place Fake Buy</button></form><a href="/search" class="button secondary wide-link">Search first and ask AI</a></div><div class="card"><h2>Fake Sell</h2><form method="POST" action="/sandbox/sell" class="stack"><label>Holding</label><select name="symbol"><% stats.rows.forEach(r => { %><option value="<%= r.symbol %>"><%= r.symbol %> — owned <%= r.units %></option><% }) %></select><label>Units</label><input name="units" type="number" step="0.0001" value="1"><label>Reason</label><input name="reason"><button>Place Fake Sell</button></form><form method="POST" action="/sandbox/reset" class="reset-form"><button class="danger">Reset Sandbox</button></form></div></section><section class="card"><h2>Paper Holdings</h2><div class="table-card inner"><table><thead><tr><th>Holding</th><th>Units</th><th>Avg</th><th>Current</th><th>Value</th><th>Gain</th></tr></thead><tbody><% if (!stats.rows.length) { %><tr><td colspan="6">No fake holdings yet.</td></tr><% } %><% stats.rows.forEach(r => { %><tr><td><strong><%= r.symbol %></strong><br><small><%= r.stock.name %></small></td><td><%= r.units %></td><td>$<%= Number(r.avg_price).toFixed(2) %></td><td>$<%= r.stock.price.toFixed(2) %></td><td>$<%= r.value.toFixed(2) %></td><td><%= r.gain >= 0 ? "+" : "" %>$<%= r.gain.toFixed(2) %></td></tr><% }) %></tbody></table></div></section><section class="card"><h2>Trade History</h2><% stats.trades.forEach(t => { %><div class="trade-row <%= String(t.action).toLowerCase() %>"><strong><%= t.action %> <%= t.units %> <%= t.symbol %></strong><small>$<%= Number(t.price).toFixed(2) %> each — <%= t.reason || "No reason recorded" %></small></div><% }) %></section>