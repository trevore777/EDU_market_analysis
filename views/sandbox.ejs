<section class="page-head">
  <h1>Sandbox Paper Trading</h1>
  <p>Practise with $10,000 virtual cash. These are fake trades only. Data persists in Turso.</p>
</section>

<% if (message) { %><div class="success"><%= message %></div><% } %>
<% if (error) { %><div class="error"><%= error %></div><% } %>

<section class="grid four">
  <div class="metric"><span>Total virtual value</span><strong>$<%= stats.totalValue.toFixed(2) %></strong></div>
  <div class="metric"><span>Virtual cash</span><strong>$<%= stats.account.cash_balance.toFixed(2) %></strong></div>
  <div class="metric"><span>Total return</span><strong><%= stats.totalGain >= 0 ? "+" : "" %>$<%= stats.totalGain.toFixed(2) %></strong></div>
  <div class="metric"><span>Health score</span><strong><%= stats.healthScore %>/100</strong></div>
</section>


<section class="card">
  <h2>Sandbox Portfolio Graph</h2>
  <p class="hint">Tracks your virtual portfolio value over time using the current paper holdings and sample price history.</p>
  <div class="chart-wrap">
    <canvas id="sandboxChart" width="900" height="320"></canvas>
  </div>
</section>

<section class="grid two">
  <div class="card">
    <h2>Fake Buy</h2>
    <form method="POST" action="/sandbox/buy" class="stack">
      <label>Share / ETF</label>
      <select name="symbol"><% stocks.forEach(s => { %><option value="<%= s.symbol %>"><%= s.symbol %> — $<%= s.price.toFixed(2) %></option><% }) %></select>
      <label>Units</label><input name="units" type="number" step="0.0001" value="1" required>
      <label>Reason for fake trade</label><input name="reason" placeholder="e.g. Broad ETF, strong rating, diversification">
      <button>Place Fake Buy</button>
    </form>
  </div>
  <div class="card">
    <h2>Fake Sell</h2>
    <form method="POST" action="/sandbox/sell" class="stack">
      <label>Holding</label>
      <select name="symbol"><% stats.rows.forEach(r => { %><option value="<%= r.symbol %>"><%= r.symbol %> — owned <%= r.units %></option><% }) %></select>
      <label>Units</label><input name="units" type="number" step="0.0001" value="1" required>
      <label>Reason for fake sell</label><input name="reason" placeholder="e.g. Rebalancing, taking profit, reducing risk">
      <button>Place Fake Sell</button>
    </form>
    <form method="POST" action="/sandbox/reset" onsubmit="return confirm('Reset sandbox to $10,000 virtual cash?')" class="reset-form">
      <button class="danger">Reset Sandbox</button>
    </form>
  </div>
</section>

<section class="card">
  <h2>Paper Holdings</h2>
  <div class="table-card inner"><table>
    <thead><tr><th>Holding</th><th>Units</th><th>Avg price</th><th>Current price</th><th>Value</th><th>Gain/Loss</th></tr></thead>
    <tbody>
    <% if (!stats.rows.length) { %><tr><td colspan="6">No fake holdings yet. Place a fake buy above.</td></tr><% } %>
    <% stats.rows.forEach(r => { %>
      <tr><td><strong><%= r.symbol %></strong><br><small><%= r.stock.name %></small></td><td><%= r.units %></td><td>$<%= r.avg_price.toFixed(2) %></td><td>$<%= r.stock.price.toFixed(2) %></td><td>$<%= r.value.toFixed(2) %></td><td><%= r.gain >= 0 ? "+" : "" %>$<%= r.gain.toFixed(2) %> (<%= r.gainPct.toFixed(2) %>%)</td></tr>
    <% }) %>
    </tbody>
  </table></div>
</section>

<section class="grid two">
  <div class="card">
    <h2>Sandbox Risk Check</h2>
    <p><strong>Largest sector:</strong> <%= stats.largestSector[0] %></p>
    <p><strong>Concentration:</strong> <%= stats.concentrationRisk.toFixed(1) %>%</p>
    <p><strong>Average rating:</strong> <%= stats.avgRating.toFixed(1) %>/100</p>
    <p class="hint">The aim is to practise decisions, not chase fake short-term wins.</p>
  </div>
  <div class="card">
    <h2>Trade History</h2>
    <% if (!stats.trades.length) { %><p>No fake trades yet.</p><% } %>
    <% stats.trades.forEach(t => { %>
      <div class="trade-row <%= String(t.action).toLowerCase() %>">
        <strong><%= t.action %> <%= t.units %> <%= t.symbol %></strong>
        <small>$<%= Number(t.price).toFixed(2) %> each — $<%= Number(t.total_value).toFixed(2) %><br><%= t.reason || "No reason recorded" %><br><%= t.created_at %></small>
      </div>
    <% }) %>
  </div>
</section>