<section class="hero">
  <div>
    <p class="eyebrow">Search + guided AI prompts</p>
    <h1>Find shares, ask better questions, and practise with fake trades.</h1>
    <p class="lede">Stage 9 adds a beginner-friendly AI prompt builder, share search, compare workflow, charts and sandbox paper trading.</p>
    <div class="actions">
      <% if (user) { %>
        <a class="button" href="/search">Search + Ask AI</a>
        <a class="button secondary" href="/sandbox">Open Sandbox</a>
      <% } else { %>
        <a class="button" href="/login">Login</a>
        <a class="button secondary" href="/register">Create Account</a>
      <% } %>
    </div>
    <p class="hint">Demo login: <strong>demo@shares.app</strong> / <strong>demo123</strong></p>
  </div>
  <div class="card">
    <h3>Top sample ratings</h3>
    <% stocks.forEach(s => { %>
      <a class="mini-stock" href="/stock/<%= s.symbol %>">
        <span><strong><%= s.symbol %></strong><small><%= s.name %></small></span>
        <b><%= s.rating %></b>
      </a>
    <% }) %>
  </div>
</section>