<section class="hero">
  <div>
    <p class="eyebrow">Vercel + Turso ready</p>
    <h1>Paper trading sandbox with persistent cloud database support.</h1>
    <p class="lede">Stage 8 replaces local SQLite with Turso/libSQL so your login, paper trades and sandbox data can persist on Vercel.</p>
    <div class="actions">
      <% if (user) { %><a class="button" href="/sandbox">Open Sandbox</a><% } else { %><a class="button" href="/login">Login</a><a class="button secondary" href="/register">Create Account</a><% } %>
    </div>
    <p class="hint">Demo login after migration: <strong>demo@shares.app</strong> / <strong>demo123</strong></p>
  </div>
  <div class="card">
    <h3>Top sample ratings</h3>
    <% stocks.forEach(s => { %>
      <a class="mini-stock" href="/stock/<%= s.symbol %>"><span><strong><%= s.symbol %></strong><small><%= s.name %></small></span><b><%= s.rating %></b></a>
    <% }) %>
  </div>
</section>