<section class="page-head"><h1>AI Coach</h1><p>Ask for a review of your sandbox portfolio.</p></section><form class="coach-form" method="POST"><textarea name="question" rows="4"><%= question %></textarea><button>Ask Coach</button></form><p class="hint">For guided questions, use <a href="/search">Live Search + AI</a>.</p><% if (answer) { %><section class="card coach-answer"><h2><%= answer.title %></h2><p class="lede"><%= answer.summary %></p><ul><% answer.points.forEach(p => { %><li><%= p %></li><% }) %></ul></section><% } %>