<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/styles.css">
</head>
<body>

<header class="topbar">
  <a class="brand" href="/">
    Simple Shares <span>Kunpeng Ready</span>
  </a>

  <nav>
    <a href="/">Home</a>
    <a href="/stocks">Ratings</a>

    <% if (user) { %>
      <a href="/search">Live Search + AI</a>
      <a href="/sandbox">Sandbox</a>
      <a href="/watchlist">Watchlist</a>
      <a href="/news">Market News</a>
      <a href="/coach">AI Coach</a>

      <form method="POST" action="/logout" class="inline">
        <button class="linkbtn">Logout</button>
      </form>
    <% } else { %>
      <a href="/login">Login</a>
      <a href="/register">Register</a>
    <% } %>
  </nav>
</header>

<div class="sandbox-banner">
  SANDBOX MODE — Educational use only. Not financial advice.
</div>

<main class="container">
  <%- body %>
</main>

<footer class="footer">
  Kunpeng realtime prices • Curated market news • Turso Cache
</footer>

<script src="/js/app.js"></script>

</body>
</html>
