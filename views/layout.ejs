<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/styles.css">
</head>
<body>
<header class="topbar">
  <a class="brand" href="/">Simple Shares <span>Stage 7</span></a>
  <nav>
    <a href="/stocks">Ratings</a>
    <a href="/simulator">Simulator</a>
    <% if (user) { %>
      <a href="/sandbox">Sandbox</a>
      <a href="/coach">AI Coach</a>
      <form method="POST" action="/logout" class="inline"><button class="linkbtn">Logout</button></form>
    <% } else { %>
      <a href="/login">Login</a>
      <a href="/register">Register</a>
    <% } %>
  </nav>
</header>
<div class="sandbox-banner">SANDBOX MODE: fake money, fake trades, educational simulation only. Turso database ready.</div>
<main class="container"><%- body %></main>
<footer class="footer">Educational prototype only. No real trades are placed. Not personal financial advice.</footer>
<script src="/js/app.js"></script>
</body>
</html>